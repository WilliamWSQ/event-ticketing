{
  "name": "pulse-concert-booking",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "node scripts/free-ports.mjs 5173 4000 && concurrently -k -n web,api -c cyan,magenta \"vite\" \"yarn --cwd backend dev\"",
    "dev:web": "node scripts/free-ports.mjs 5173 && vite",
    "dev:api": "node scripts/free-ports.mjs 4000 && yarn --cwd backend dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "lucide-react": "^0.439.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "styled-components": "^6.1.13"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "babel-plugin-styled-components": "^2.1.4",
    "concurrently": "^10.0.3",
    "typescript": "^5.5.3",
    "vite": "^5.4.0"
  }
}
